# Test Environment Configuration
# Copy this file to .env and fill in your actual API credentials

# Finnhub API Configuration
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpaca API Credentials - Paper Trading
PAPER_ALPACA_API_KEY=your_paper_api_key_here
PAPER_ALPACA_SECRET_KEY=your_paper_secret_key_here

# Alpaca API Credentials - Live Trading
LIVE_ALPACA_API_KEY=your_live_api_key_here
LIVE_ALPACA_SECRET_KEY=your_live_secret_key_here

# Alpaca Configuration
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_PAPER_TRADING=true

# Trading Configuration
RISK_PERCENTAGE=1.0
AUTO_TRADING_ENABLED=false

# Database Configuration
DATABASE_PATH=trading_app.db

# Logging Configuration
LOG_LEVEL=INFO
